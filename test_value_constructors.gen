# Test Bool constructor
print(Bool(true)); # expect: true
print(Bool(false)); # expect: false
print(Bool(1)); # expect: true
print(Bool(0)); # expect: false
print(Bool("hello")); # expect: true
print(Bool("")); # expect: false
print(Bool(nil)); # expect: false

# Test String constructor
print(String(42)); # expect: 42
print(String(true)); # expect: true
print(String(false)); # expect: false
print(String("hello")); # expect: hello

# Test Integer constructor
print(Integer(42)); # expect: 42
print(Integer("123")); # expect: 123
print(Integer(3.14)); # expect: 3
print(Integer(true)); # expect: 1
print(Integer(false)); # expect: 0

# Test Float constructor
print(Float(42)); # expect: 42.0
print(Float("3.14")); # expect: 3.14
print(Float(true)); # expect: 1.0
print(Float(false)); # expect: 0.0

# Test Rational constructor
print(Rational(1, 2)); # expect: 1/2
print(Rational(3, 4)); # expect: 3/4
print(Rational(6, 8)); # expect: 3/4