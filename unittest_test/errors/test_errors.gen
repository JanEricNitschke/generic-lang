# ERROR-outcome fixture: a test function that cannot be invoked (it takes
# parameters) is reported as ERROR and fails the run - the runner also
# validates the exit code (1) derived from the summary line.
# expect: Running tests in unittest_test/errors/test_errors.gen...
# expect:
# expect: Running 2 test(s)...
# expect:
# expect:   test_that_errors ... ERROR
# expect:     Failed to call test function
# expect:   test_that_passes ... PASS
# expect: === Test Results ===
# expect: Tests run: 2
# expect: ✓ Passed: 1
# expect: ❌ Errors: 1
# expect:
# expect: Some tests failed or had errors.

fun test_that_passes() {
    assert(1 + 1 == 2);
}

fun test_that_errors(a, b) {
    assert(a + b == a + a - a + b);
}
