# Exceptions caught inside __iter__/__next__ while a native (the List
# constructor) drives the iteration must not disturb the native.
class Once {
    __init__() {
        this.done = false;
    }

    __iter__() {
        try {
            throw ValueError("iter");
        } catch ValueError as e {
            return this;
        }
    }

    __next__() {
        try {
            throw ValueError("next");
        } catch ValueError as e {
            if (this.done) {
                return StopIteration;
            }
            this.done = true;
            return 42;
        }
    }
}

print(List(Once())); # expect: [42]
print("after"); # expect: after
