class Error1 < Exception {}
class Error2 < Exception {}


try {
    try {
        throw Error1("error message");
    } catch Error1 as e1 {
        print(e1);  # expect: error message
        throw Error2("error message");
    } catch Error2 as e2 {
        print(e2);
    }
} catch Error2 as e {
    print(e);   # expect: error message
}


try {
    try {
        throw Error2("error message");
    } catch Error1 as e1 {
        print(e1);
    } catch Error2 as e2 {
        print(e2);  # expect: error message
        throw Error1("error message");
    }
} catch Error1 as e {
    print(e);   # expect: error message
}
