var list = ["A"];
list[0] += "B";
print(list); # expect: [AB]


list = [5];
var index = 0;
print(list); # expect: [5]
list[0] = 6;
print(list); # expect: [6]
list[index] *= 2;
print(list); # expect: [12]
list[0] *= true; # expect runtime error: TypeError: Operands must be two numbers, string * integer, or support `__mul__`. Got: [12, true]
print(list);