# Ordering across incompatible container types raises a TypeError.

try {
    [1] < (1, 2);
} catch TypeError as e {
    print(e); # expect: Can only compare a list to another list, got `(1, 2)`.
}

try {
    [1] < 5;
} catch TypeError as e {
    print(e); # expect: Can only compare a list to another list, got `5`.
}

try {
    (1,) < [1];
} catch TypeError as e {
    print(e); # expect: Can only compare a tuple to another tuple, got `[1]`.
}

# Unorderable elements propagate the element TypeError.
try {
    [1] < ["a"];
} catch TypeError as e {
    print(e); # expect: Operands must be numbers, strings or support `__lt__`. Got: [1, a]
}

# Sets and dicts are not ordered at all.
var s1 = {1};
var s2 = {2};
try {
    s1 < s2;
} catch TypeError as e {
    print(e); # expect: Operands must be numbers, strings or support `__lt__`. Got: [{1}, {2}]
}

var d1 = {1: 2};
var d2 = {1: 3};
try {
    d1 <= d2;
} catch TypeError as e {
    print(e); # expect: Operands must be numbers, strings or support `__le__`. Got: [{1: 2}, {1: 3}]
}
