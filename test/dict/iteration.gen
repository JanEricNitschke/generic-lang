var my_dict = {1: "Apple", 2: "Banana", 3: "Pear"};
foreach (var key in my_dict) {
    print(key);  # expect: 2
                 # expect: 3
                 # expect: 1
}

foreach (var key in my_dict.keys()) {
    print(key);  # expect: 2
                 # expect: 3
                 # expect: 1
}

foreach (var value in my_dict.values()) {
    print(value);  # expect: Banana
                 # expect: Pear
                 # expect: Apple
}

foreach (var item in my_dict.items()) {
    print(item);  # expect: (2, Banana)
                 # expect: (3, Pear)
                 # expect: (1, Apple)
}
