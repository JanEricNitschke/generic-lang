# `:` binds tigther than `**`, so we get `(5:3)**2` instead of `5:(3**2)`
print(5:3**2);  # expect: 25:9

# Also binds tighter than call level `.`.
# `2:3.foo` is `(2:3).foo` not `2:(3.foo)`
# As rational dont support any Call level syntax (`.`, `()`, `[]`) we have
# to check against the error
try {
    var unreached = 2:3.foo;
    print(unreached);
} catch Exception as e {
    print(str(e));  # expect: Tried to get property 'foo' of non-instance `2:3`.
}
